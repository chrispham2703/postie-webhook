generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users   User[]
  apiKeys ApiKey[]
  apps    Application[]

  @@map("organizations")
}


model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("member")
  orgId        String
  createdAt    DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("users")
}

model ApiKey {
  id         String    @id
  keyHash    String    @unique
  prefix     String
  name       String
  orgId      String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("api_keys")
}

model Application {
  id        String   @id
  orgId     String
  name      String
  uid       String?
  metadata  Json?
  createdAt DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endpoints Endpoint[]
  events    Event[]

  @@unique([orgId, uid])
  @@index([orgId])
  @@map("applications")
}

model Endpoint {
  id           String   @id
  appId        String
  url          String
  secret       String
  description  String?
  filterTypes  String[]
  headers      Json?
  status       String   @default("active")
  failureCount Int      @default(0)
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  app        Application @relation(fields: [appId], references: [id], onDelete: Cascade)
  deliveries Delivery[]

  @@index([appId])
  @@map("endpoints")
}

model Event {
  id        String   @id
  appId     String
  messageId String?  @unique
  eventType String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  app        Application @relation(fields: [appId], references: [id], onDelete: Cascade)
  deliveries Delivery[]

  @@index([appId])
  @@map("events")
}

model Delivery {
  id            String    @id
  eventId       String
  endpointId    String
  status        String    @default("pending")
  attemptCount  Int       @default(0)
  nextAttemptAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  endpoint Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  attempts DeliveryAttempt[]

  @@unique([eventId, endpointId])
  @@index([nextAttemptAt])
  @@index([endpointId])
  @@map("deliveries")
}

model DeliveryAttempt {
  id           String   @id
  deliveryId   String
  attemptNum   Int
  statusCode   Int
  responseBody String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("delivery_attempts")
}

