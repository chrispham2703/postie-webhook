generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users   User[]
  apiKeys ApiKey[]

  @@map("organizations")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("member")
  orgId        String
  createdAt    DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("users")
}

model ApiKey {
  id         String    @id
  keyHash    String    @unique
  prefix     String
  name       String
  orgId      String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("api_keys")
}

model Endpoint {
  id           String   @id
  url          String
  status       String   @default("active") // active / circuit-open
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  events       Event[]

  @@map("endpoints")
}

model Event {
  id        String   @id
  eventType String
  payload   Json
  targetUrl String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  attemptCount Int @default(0)
  nextAttemptAt DateTime?
  endpointId       String

  @@index([nextAttemptAt])

  // not allow to delete endpoint if that event still keep history
  endpoint         Endpoint          @relation(fields: [endpointId], references: [id], onDelete: Restrict)
  deliveryAttempts DeliveryAttempt[]

  @@index([endpointId])
  @@map("events")
}

model DeliveryAttempt {
  id           String   @id
  statusCode   Int
  attemptNum   Int
  responseBody String?
  createdAt    DateTime @default(now())
  durationMs    Int?

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("delivery_attempts")
}

